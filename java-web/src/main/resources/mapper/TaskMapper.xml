<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.manim.mapper.TaskMapper">

    <!-- 基础结果映射 -->
    <resultMap id="BaseResultMap" type="com.manim.pojo.Task">
        <id column="id" property="id" jdbcType="INTEGER"/>
        <result column="user_id" property="userId" jdbcType="INTEGER"/>
        <result column="user_input" property="userInput" jdbcType="VARCHAR"/>
        <result column="video_path" property="videoPath" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="TINYINT"/>
        <result column="error_log" property="errorLog" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <!-- 通用查询列 -->
    <sql id="BaseColumns">
        id, user_id, user_input, video_path, status, error_log, create_time, update_time
    </sql>

</mapper>
